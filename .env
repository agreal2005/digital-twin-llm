# ── Model
MODEL_PATH=/home/agreal2016/btp/models/Llama-3.2-3B-Instruct-Q4_K_M.gguf
MODEL_N_CTX=16384
MODEL_N_THREADS=8

# ── API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# ── LLM policy
AUTO_APPROVE_CONFIDENCE=0.75
REQUIRE_HUMAN_ACTIONS=restart,restart_device,update_config,delete_interface,shutdown

# ── Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Context builder mode: "live" uses real DBs, "stub" uses hardcoded data
CONTEXT_BUILDER_MODE=live
